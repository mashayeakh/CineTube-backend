model Movie {
  id            String              @id @default(cuid())
  title         String              @unique
  description   String
  poster        String
  releaseYear   Int
  director      String
  cast          String
  priceType     PriceType           @default(FREE)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  userId        String
  ageGroup      AgeGroup
  streamingLink String
  user          User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  payments      Payment[]
  reviews       Review[]
  watchlists    WatchList[]
  genres        Genre[]             @relation("MovieGenres")
  platforms     StreamingPlatform[] @relation("MoviePlatforms")

  @@index([userId])
  @@map("movie")
}
