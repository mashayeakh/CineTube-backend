model Movie {
    id                String      @id @default(cuid())
    title             String
    description       String
    poster            String
    releaseYear       Int
    director          String
    cast              String      @db.Text // Could be JSON array or string
    genres            String      @db.Text // JSON array or comma-separated
    streamingPlatform String
    priceType         PriceType   @default(FREE)
    createdAt         DateTime    @default(now())
    updatedAt         DateTime    @updatedAt
    reviews           Review[]
    payments          Payment[]
    watchlists        WatchList[]

    // Foreign Key to User
    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("movie")
}
