model Movie {
    id                String      @id @default(cuid())
    title             String
    description       String
    poster            String
    releaseYear       Int
    director          String
    cast              String      @db.Text
    genres            String      @db.Text
    streamingPlatform String
    ageGroup          AgeGroup
    priceType         PriceType   @default(FREE)
    createdAt         DateTime    @default(now())
    updatedAt         DateTime    @updatedAt
    reviews           Review[]
    payments          Payment[]
    watchlists        WatchList[]

    // Foreign Key to User
    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([title])
    @@index([userId])
    @@map("movie")
}
