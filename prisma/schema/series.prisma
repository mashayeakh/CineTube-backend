model Series {
  id            String               @id @default(cuid())
  title         String               @unique
  description   String
  poster        String
  releaseYear   Int
  director      String
  cast          String
  ageGroup      AgeGroup
  priceType     PriceType            @default(FREE)
  totalSeasons  Int
  totalEpisodes Int?
  status        SeriesStatus         @default(ONGOING)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  userId        String
  featuredAt    DateTime?
  featuredBy    String?
  isFeatured    Boolean              @default(false)
  streamingLink String
  reviews       Review[]
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackings     UserSeriesTracking[]
  watchLists    WatchList[]
  genres        Genre[]              @relation("SeriesGenres")
  platforms     StreamingPlatform[]  @relation("SeriesPlatforms")

  @@index([userId])
  @@index([isFeatured])
  @@map("series")
}
