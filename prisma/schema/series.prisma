model Series {
    id            String               @id @default(cuid())
    title         String
    description   String
    poster        String
    releaseYear   Int
    director      String
    cast          String               @db.Text
    ageGroup      AgeGroup
    priceType     PriceType            @default(FREE)
    totalSeasons  Int
    totalEpisodes Int?
    status        SeriesStatus         @default(ONGOING)
    isFeatured    Boolean              @default(false)
    featuredAt    DateTime?
    featuredBy    String?
    createdAt     DateTime             @default(now())
    updatedAt     DateTime             @updatedAt
    userId        String
    user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
    trackings     UserSeriesTracking[]

    genres     Genre[]             @relation("SeriesGenres")
    platforms  StreamingPlatform[] @relation("SeriesPlatforms")
    watchLists WatchList[]

    @@unique([title])
    @@index([userId])
    @@index([isFeatured])
    @@map("series")
}
