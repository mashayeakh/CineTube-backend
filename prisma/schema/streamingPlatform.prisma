model StreamingPlatform {
    id                  String               @id @default(cuid())
    name                String               @unique
    movies              Movie[]              @relation("MoviePlatforms")
    series              Series[]             @relation("SeriesPlatforms")
    movieContributions  MovieContribution[]  @relation("MovieContributionPlatforms")
    seriesContributions SeriesContribution[] @relation("SeriesContributionPlatforms")
    userPreferences     UserPreference[]     @relation("UserPreferencePlatforms")

    @@map("streaming_platform")
}
