model Genre {
  id                  String               @id @default(cuid())
  name                String               @unique
  movieContributions  MovieContribution[]  @relation("MovieContributionGenres")
  movies              Movie[]              @relation("MovieGenres")
  seriesContributions SeriesContribution[] @relation("SeriesContributionGenres")
  series              Series[]             @relation("SeriesGenres")
  userPreferences     UserPreference[]     @relation("UserPreferenceGenres")

  @@map("genre")
}
