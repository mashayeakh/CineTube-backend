model MovieContribution {
    id String @id @default(cuid())

    contributorId String
    contributor   User   @relation(fields: [contributorId], references: [id], onDelete: Cascade)

    title       String
    description String @db.Text
    poster      String
    releaseYear Int
    director    String

    // store cast as JSON string (simple + flexible)
    cast String @db.Text

    // RELATIONS (same pattern as Movie model)
    genres    Genre[]             @relation("MovieContributionGenres")
    platforms StreamingPlatform[] @relation("MovieContributionPlatforms")

    ageGroup AgeGroup

    status MovieStatus @default(PENDING)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([contributorId])
    @@map("movie_contribution")
}
