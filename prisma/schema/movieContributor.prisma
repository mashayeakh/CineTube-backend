model MovieContribution {
  id            String              @id @default(cuid())
  contributorId String
  title         String
  description   String
  poster        String
  releaseYear   Int
  director      String
  cast          String
  ageGroup      AgeGroup
  status        MovieStatus         @default(PENDING)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  streamingLink String
  contributor   User                @relation(fields: [contributorId], references: [id], onDelete: Cascade)
  genres        Genre[]             @relation("MovieContributionGenres")
  platforms     StreamingPlatform[] @relation("MovieContributionPlatforms")

  @@unique([title, contributorId])
  @@index([contributorId])
  @@map("movie_contribution")
}
