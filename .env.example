NODE_ENV=development
PORT=5000

# Development database only (never production)
DATABASE_URL="postgresql://<dev_user>:<dev_password>@<dev_host>/<dev_db>?sslmode=require"

BETTER_AUTH_SECRET=replace_with_dev_secret
BETTER_AUTH_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_dev_admin_password

EMAIL_SENDER_SMTP_USER=replace_with_dev_smtp_user
EMAIL_SENDER_SMTP_PASS=replace_with_dev_smtp_password
EMAIL_SENDER_SMTP_HOST=smtp.gmail.com
EMAIL_SENDER_SMTP_PORT=465
EMAIL_SENDER_SMTP_FROM=replace_with_dev_smtp_from

STRIPE_WEBHOOK_SECRET=replace_with_dev_stripe_webhook_secret
ACCESS_TOKEN_SECRET=replace_with_dev_access_token_secret
REFRESH_TOKEN_SECRET=replace_with_dev_refresh_token_secret

ACCESS_TOKEN_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=7d

BETTER_AUTH_SESSION_TOKEN_EXPIRES_IN=1d
BETTER_AUTH_SESSION_TOKEN_UPDATE_AGE=1d

STRIPE_SECRET_KEY=replace_with_dev_stripe_secret_key
